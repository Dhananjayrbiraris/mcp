# ============================================================
# Elasticsearch MCP Server – Environment Configuration
# Copy this file to .env and fill in your values.
# ============================================================

# --- Connection --------------------------------------------------
# Comma-separated list of Elasticsearch hosts
ELASTICSEARCH_HOSTS=http://localhost:9200

# Basic auth (use ONE of: basic auth OR API key)
# ELASTICSEARCH_USERNAME=elastic
# ELASTICSEARCH_PASSWORD=changeme

# API Key auth (preferred for production)
# ELASTICSEARCH_API_KEY=your_api_key_here

# TLS / SSL
# ELASTICSEARCH_CA_CERTS=/path/to/ca.crt
# ELASTICSEARCH_VERIFY_CERTS=true

# --- Timeouts & retries ------------------------------------------
ELASTICSEARCH_TIMEOUT=30
ELASTICSEARCH_MAX_RETRIES=3

# --- Semantic search defaults ------------------------------------
# Sparse ELSER model (English)
ELASTICSEARCH_DEFAULT_MODEL_ID=.elser_model_2

# Dense embedding model (multilingual)
ELASTICSEARCH_DENSE_MODEL_ID=.multilingual-e5-small

# Default number of results to return
ELASTICSEARCH_DEFAULT_TOP_K=10

# ANN candidate pool size for kNN
ELASTICSEARCH_NUM_CANDIDATES=100

# Minimum _score threshold for results
ELASTICSEARCH_MIN_SCORE=0.0
